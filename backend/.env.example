# Server port
PORT=3001

# JWT secret key (change this to a random string in production)
JWT_SECRET=performance-app-secret-key-2024

# Firebase Admin SDK credentials
# Option 1: Full service account JSON (paste the entire JSON from Firebase Console)
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"performance-200aa",...}

# Option 2: Individual fields (if not using FIREBASE_SERVICE_ACCOUNT)
# FIREBASE_PRIVATE_KEY_ID=your-private-key-id
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@performance-200aa.iam.gserviceaccount.com
# FIREBASE_CLIENT_ID=your-client-id
# FIREBASE_CLIENT_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/...
